@page
@model IndexModel
@{
    ViewData["Title"] = "Ana Sayfa";
}

<style>
    /* MODERN SAAS UI - LANDING PAGE STYLES */
    
    /* Background Blob Animation Effects */
    .hero-bg {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        overflow: hidden;
        z-index: -1;
        background-color: #fcfdfd;
    }
    .wave-bar {
        display: inline-block;
        width: 3px;
        background: #0d6efd; 
        border-radius: 10px;
        margin: 0 1px;
        vertical-align: middle;
        animation: wave 1s infinite ease-in-out;
    }
    
    .blob {
        position: absolute;
        filter: blur(80px);
        opacity: 0.4;
        border-radius: 50%;
        animation: float 10s infinite ease-in-out alternate;
    }
    .blob-1 { top: -10%; left: -10%; width: 500px; height: 500px; background: rgba(13, 110, 253, 0.4); }
    .blob-2 { top: 40%; right: -10%; width: 400px; height: 400px; background: rgba(25, 135, 84, 0.3); animation-delay: -5s; }
    .blob-3 { bottom: -20%; left: 20%; width: 600px; height: 600px; background: rgba(111, 66, 193, 0.2); animation-delay: -2s; }

    @@keyframes float {
        0% { transform: translateY(0px) scale(1); }
        100% { transform: translateY(30px) scale(1.05); }
    }
    @@keyframes wave {
        0%, 100% { height: 5px; }
        50% { height: 18px; }
    }

    /* Gradient Typography */
    .text-gradient {
        background: linear-gradient(135deg, #0d6efd 0%, #6f42c1 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    /* Glassmorphism Soft Cards */
    .soft-card {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.9);
        border-radius: 1.5rem;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.04);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .soft-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
    }

    .icon-container-lg {
        width: 65px;
        height: 65px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 1.2rem;
        font-size: 1.5rem;
    }

    /* Soft Color Palettes */
    .bg-soft-primary { background-color: rgba(13, 110, 253, 0.06); color: #0d6efd; }
    .bg-soft-success { background-color: rgba(25, 135, 84, 0.06); color: #198754; }
    .bg-soft-danger { background-color: rgba(220, 53, 69, 0.06); color: #dc3545; }

    /* Scroll-triggered Fade-In Utilities */
    .fade-in-section {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.8s ease-out, transform 0.8s ease-out;
        will-change: opacity, visibility;
    }
    .fade-in-section.is-visible {
        opacity: 1;
        transform: none;
    }
</style>

<div class="hero-bg">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
</div>

<div class="container pb-5" style="margin-top: 6rem; max-width: 1200px;">
    
    <div class="row align-items-center min-vh-75 mb-5 pb-5 fade-in-section is-visible">
        
        <div class="col-lg-6 text-center text-lg-start mb-5 mb-lg-0 z-1">
            <h1 class="display-4 fw-extrabold text-dark mb-4" style="font-weight: 800; letter-spacing: -1.5px; line-height: 1.1;">
                Toplantılarınızı <br />
                <span class="text-gradient">Yapay Zeka</span> ile <br /> Yeniden Keşfedin
            </h1>
            <p class="lead text-muted mb-5 pe-lg-4" style="font-size: 1.15rem; line-height: 1.8;">
                Uzun ve yorucu toplantı kayıtlarınızı yapay zeka ile kusursuzca analiz edin. Görüşülen konuları özetleyin, kararları ayıklayın ve tüm ekibinizle kolayca paylaşın.
            </p>
            <div class="d-flex justify-content-center justify-content-lg-start gap-3 flex-wrap">
                <a asp-page="/Upload" class="btn btn-primary btn-lg rounded-pill shadow px-5 py-3 fw-bold transition-all hover-scale">
                    Hemen Başla <i class="bi bi-arrow-right ms-2"></i>
                </a>
                <a asp-page="/History" class="btn btn-white btn-lg rounded-pill px-4 py-3 fw-bold text-dark border shadow-sm transition-all hover-bg-light">
                    Arşivi Gör
                </a>
            </div>
            
            <div class="d-flex align-items-center justify-content-center justify-content-lg-start mt-5 gap-3 text-muted small fw-medium">
                <span><i class="bi bi-shield-check text-success fs-5 me-1"></i> Uçtan Uca Şifreli</span>
                <span class="text-light">|</span>
                <span><i class="bi bi-ui-checks text-primary fs-5 me-1"></i> Kullanıcı Dostu Arayüz</span>
            </div>
        </div>

        <div class="col-lg-6 position-relative z-1">
            <div class="position-relative mx-auto" style="max-width: 500px;">
                
                <div class="soft-card p-4 p-md-5 position-relative z-2">
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="spinner-grow text-primary spinner-grow-sm" role="status"></div>
                        <h5 class="fw-bold mb-0 text-dark">Q3 Finans Raporu.m4a</h5>
                    </div>
                    <div class="mb-3">
                        <div class="bg-light rounded-pill mb-2" style="height: 12px; width: 85%;"></div>
                        <div class="bg-light rounded-pill mb-2" style="height: 12px; width: 70%;"></div>
                        <div class="bg-light rounded-pill mb-4" style="height: 12px; width: 90%;"></div>
                    </div>
                    <div class="border-top pt-4">
                        <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2 fw-medium mb-2"><i class="bi bi-check2-circle me-1"></i> 3 Karar Alındı</span>
                        <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-3 py-2 fw-medium"><i class="bi bi-lightning-charge me-1"></i> 2 Aksiyon Bekliyor</span>
                    </div>
                </div>

                <div class="soft-card p-3 position-absolute z-1 shadow-sm" style="top: -20px; right: -15px; width: 200px; transform: rotate(3deg);">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px;"><i class="bi bi-mic-fill text-primary"></i></div>
                        <div class="d-flex align-items-end gap-1" style="height: 20px;">
                            <div class="wave-bar" style="animation-delay: 0.1s; height: 12px;"></div>
                            <div class="wave-bar" style="animation-delay: 0.3s; height: 18px;"></div>
                            <div class="wave-bar" style="animation-delay: 0.2s; height: 10px;"></div>
                            <div class="wave-bar" style="animation-delay: 0.5s; height: 15px;"></div>
                            <div class="wave-bar" style="animation-delay: 0.4s; height: 8px;"></div>
                            <div class="wave-bar" style="animation-delay: 0.6s; height: 14px;"></div>
                            <div class="wave-bar" style="animation-delay: 0.2s; height: 11px;"></div>
                            <div class="wave-bar" style="animation-delay: 0.4s; height: 16px;"></div>
                            <div class="wave-bar" style="animation-delay: 0.1s; height: 9px;"></div>
                            <div class="wave-bar" style="animation-delay: 0.3s; height: 13px;"></div>
                            <div class="wave-bar" style="animation-delay: 0.5s; height: 10px;"></div>
                        </div>
                    </div>
                </div>

                <div class="soft-card p-3 position-absolute z-3" style="bottom: -20px; left: -30px; width: 240px; transform: rotate(-3deg);">
                    <div class="d-flex align-items-center gap-2">
                        <img src="https://ui-avatars.com/api/?name=Briefyn+AI&background=0D8ABC&color=fff" class="rounded-circle" style="width: 30px; height: 30px;" />
                        <div>
                            <div class="text-dark fw-bold" style="font-size: 0.75rem;">Rapor Paylaşıldı</div>
                            <div class="text-muted" style="font-size: 0.65rem;">Tüm ekibe mail gönderildi</div>
                        </div>
                    </div>
                </div>

            </div>
        </div>

    </div>

    <div class="py-5 mt-5 fade-in-section">
        <div class="text-center mb-5 pb-3">
            <h6 class="text-primary fw-bold text-uppercase tracking-wider">İş Akışı</h6>
            <h2 class="fw-bold text-dark mb-3">Sadece 3 Adımda Mükemmel Sonuç</h2>
            <p class="text-muted mx-auto" style="max-width: 600px;">Sistemi kullanmak için teknik bir bilgiye ihtiyacınız yok. Süreç tamamen otomatik ilerler.</p>
        </div>

        <div class="row g-4 position-relative justify-content-center">
            <div class="d-none d-lg-block position-absolute border-top border-2" 
                style="top: 33px; 
                left: 50%; 
                width: 66%; 
                transform: translateX(-50%); 
                z-index: 0; 
                border-style: dashed !important; 
                border-color: #dee2e6 !important;">
            </div>
            
            <div class="col-lg-4 text-center position-relative z-1">
                <div class="icon-container-lg bg-white mb-4 mx-auto position-relative z-2">
                    <i class="bi bi-cloud-arrow-up-fill"></i>
                </div>
                <h4 class="fw-bold text-dark">1. Yükleyin</h4>
                <p class="text-muted px-3 small">Toplantınızın ses kaydını (.mp3, .wav, .m4a) güvenli sunucularımıza yükleyin.</p>
            </div>

            <div class="col-lg-4 text-center position-relative z-1">
                <div class="icon-container-lg bg-white mb-4 mx-auto position-relative z-2 shadow-sm" style="transform: scale(1.15);">
                    <i class="bi bi-cpu-fill"></i>
                </div>
                <h4 class="fw-bold text-dark">2. AI Analiz Etsin</h4>
                <p class="text-muted px-3 small">Gelişmiş LLM modellerimiz konuşmayı metne çevirir ve kritik bağlamları ayıklar.</p>
            </div>

            <div class="col-lg-4 text-center position-relative z-1">
                <div class="icon-container-lg bg-white mb-4 mx-auto position-relative z-2">
                    <i class="bi bi-envelope-paper-fill"></i>
                </div>
                <h4 class="fw-bold text-dark">3. Özeti Alın</h4>
                <p class="text-muted px-3 small">Konular, kararlar ve görevler pürüzsüz bir arayüzle size ve ekibinize sunulur.</p>
            </div>
        </div>
    </div>

    <div class="py-5 mt-5 fade-in-section">
        <div class="row g-4">
            <div class="col-md-6 col-lg-4">
                <div class="soft-card h-100 p-4 p-md-5">
                    <div class="icon-container-lg bg-soft-primary text-primary mb-4" style="width: 50px; height: 50px; border-radius: 1rem;">
                        <i class="bi bi-mic"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-3">Akıllı Ses Tanıma</h5>
                    <p class="text-muted mb-0">Uzun sessizlikleri, mırıldanmaları ve gereksiz konuşmaları filtreleyerek sadece net içeriğe odaklanır.</p>
                </div>
            </div>
            
            <div class="col-md-6 col-lg-4">
                <div class="soft-card h-100 p-4 p-md-5">
                    <div class="icon-container-lg bg-soft-success text-success mb-4" style="width: 50px; height: 50px; border-radius: 1rem;">
                        <i class="bi bi-diagram-3"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-3">Bağlamsal Özetleme</h5>
                    <p class="text-muted mb-0">Kim ne dediğinden ziyade, toplantının ana fikrini, alınan kararları ve kimin ne yapacağını çıkarır.</p>
                </div>
            </div>
            
            <div class="col-md-6 col-lg-4">
                <div class="soft-card h-100 p-4 p-md-5">
                    <div class="icon-container-lg bg-soft-danger text-danger mb-4" style="width: 50px; height: 50px; border-radius: 1rem;">
                        <i class="bi bi-lightning-charge"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-3">Aksiyon Takibi</h5>
                    <p class="text-muted mb-0">Sistemden çıkan görevleri tek tıkla onaylayabilir, ekibinizin çalışma sürecini platform üzerinden yönetebilirsiniz.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="py-5 mt-4 mb-5 fade-in-section text-center">
        <div class="bg-dark p-5 position-relative overflow-hidden shadow-lg" style="border-radius: 2.5rem;">
            <div class="position-absolute" style="top: -50%; left: 20%; width: 400px; height: 400px; background: rgba(13, 110, 253, 0.3); filter: blur(100px); border-radius: 50%;"></div>
            
            <div class="position-relative z-1 py-4">
                <h2 class="text-white fw-bold mb-3">Saatler süren toplantıları, dakikalara indirin.</h2>
                <p class="text-white text-opacity-75 mb-4 mx-auto" style="max-width: 600px;">Artık toplantılarda kimse not tutmak zorunda değil. Dosyanızı yükleyin ve arkanıza yaslanın.</p>
                <a asp-page="/Upload" class="btn btn-primary btn-lg rounded-pill px-5 py-3 fw-bold border-0 shadow hover-scale transition-all">
                    İlk Dosyanızı Yükleyin
                </a>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        // DOM Initialization: Setup Intersection Observer for scroll-triggered animations
        document.addEventListener("DOMContentLoaded", function () {
            const observerOptions = {
                root: null,
                rootMargin: '0px',
                threshold: 0.15 
            };

            const observer = new IntersectionObserver((entries, observer) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('is-visible');
                    }
                });
            }, observerOptions);

            document.querySelectorAll('.fade-in-section').forEach((section) => {
                observer.observe(section);
            });
        });
    </script>
}