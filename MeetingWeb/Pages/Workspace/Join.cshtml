@page
@model MeetingWeb.Pages.Workspace.JoinModel
@{
    ViewData["Title"] = "Daveti Kabul Et";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6 text-center">
            
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="card shadow-sm border-0 rounded-4 overflow-hidden mt-5">
                    <div class="card-body p-5">
                        <i class="bi bi-x-circle text-danger mb-3" style="font-size: 5rem; filter: drop-shadow(0px 4px 6px rgba(220, 53, 69, 0.3));"></i>
                        <h3 class="fw-bold text-dark mt-3">Bağlantı Geçersiz</h3>
                        <p class="text-muted mt-3 fs-5" style="line-height: 1.6;">@Model.ErrorMessage</p>
                        
                        <a href="/" class="btn btn-outline-danger btn-lg rounded-pill mt-4 fw-bold px-5 shadow-sm">
                            <i class="bi bi-house-door me-2"></i> Ana Sayfaya Dön
                        </a>
                    </div>
                </div>
            }
            else
            {
                <div class="card shadow-lg border-0 rounded-4 overflow-hidden mt-4">
                    
                    <div class="bg-primary bg-gradient text-white py-5 px-4">
                        <div class="position-relative" style="z-index: 1;">
                            <i class="bi bi-envelope-paper fs-1 mb-2 d-inline-block"></i>
                            <h3 class="mb-0 fw-bold">Briefyn AI'a Davet Edildiniz!</h3>
                        </div>
                    </div>

                    <div class="card-body p-5 bg-white">
                        <h2 class="text-dark fw-bold mb-4">
                            <i class="bi bi-building text-primary me-2"></i> @Model.WorkspaceName
                        </h2>
                        <p class="text-muted mb-5 fs-5" style="line-height: 1.7;">
                            Bu çalışma alanına katılmak için davet edildiniz. Katıldığınızda, bu ekibin tüm <strong>toplantı özetlerine, kararlarına ve görevlerine</strong> anında erişebileceksiniz.
                        </p>
                        
                        <form method="post">
                            <input type="hidden" asp-for="Token" />
                            <div class="d-grid gap-2 col-10 mx-auto">
                                <button type="submit" class="btn btn-success btn-lg fw-bold rounded-pill shadow px-5 py-3 d-flex align-items-center justify-content-center transition-all hover-scale">
                                    <i class="bi bi-check-circle-fill fs-4 me-2"></i> Daveti Kabul Et ve Katıl
                                </button>
                            </div>
                        </form>
                        
                        <div class="mt-4">
                            <a href="/" class="text-muted text-decoration-none small hover-primary transition-all">
                                <i class="bi bi-arrow-left me-1"></i> Vazgeç ve Ana Sayfaya Dön
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>