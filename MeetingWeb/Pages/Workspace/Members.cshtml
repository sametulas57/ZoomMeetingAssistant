@page
@model MeetingWeb.Pages.Workspace.MembersModel
@{
    ViewData["Title"] = "Ekip Yönetimi";
}

<div class="container mt-5 mb-5">
    
    @if (TempData["StatusMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 rounded-3 d-flex align-items-center" role="alert">
            <i class="bi bi-check-circle-fill fs-5 me-3 text-success"></i>
            <div>@TempData["StatusMessage"]</div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 rounded-3 d-flex align-items-center" role="alert">
            <i class="bi bi-exclamation-triangle-fill fs-5 me-3 text-danger"></i>
            <div>@TempData["ErrorMessage"]</div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <h2 class="mb-0 text-dark fw-bold">
            <i class="bi bi-people-fill text-primary me-2"></i> @Model.WorkspaceName Ekibi
        </h2>
        
        <div class="d-flex gap-2">
            @if (Model.CurrentUserRole == "Sahip" && !Model.WorkspaceName.Contains("Kişisel"))
            {
                <button type="button" class="btn btn-outline-danger fw-bold shadow-sm rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#deleteWorkspaceModal">
                    <i class="bi bi-trash3 me-1"></i> Alanı Sil
                </button>
            }
            
            @if (Model.CurrentUserRole == "Sahip")
            {
                <a asp-page="/Workspace/Invite" class="btn btn-primary fw-bold shadow-sm rounded-pill px-4">
                    <i class="bi bi-person-plus-fill me-1"></i> Yeni Üye Davet Et
                </a>
            }
            else
            {
                <span class="d-inline-block" tabindex="0" data-bs-toggle="tooltip" title="Sadece kurucular davet gönderebilir">
                    <button class="btn btn-secondary fw-bold rounded-pill px-4 opacity-50" type="button" disabled style="pointer-events: none;">
                        <i class="bi bi-lock-fill me-1"></i> Yeni Üye Davet Et
                    </button>
                </span>
            }
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <ul class="list-group list-group-flush">
                @foreach (var member in Model.TeamMembers)
                {
                    var fullName = Model.UserNames.ContainsKey(member.UserId) ? Model.UserNames[member.UserId] : "İsimsiz Kullanıcı";
                    var avatarUrl = Model.UserAvatars.ContainsKey(member.UserId) ? Model.UserAvatars[member.UserId] : null;

                    var nameParts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                    var initials = nameParts.Length > 1
                                    ? (nameParts[0][0].ToString() + nameParts[nameParts.Length - 1][0].ToString()).ToUpper()
                                    : fullName.Substring(0, Math.Min(fullName.Length, 2)).ToUpper();

                    <li class="list-group-item d-flex flex-column flex-md-row justify-content-between align-items-md-center p-4 bg-transparent border-bottom border-light hover-bg-light transition-all">
        
                        <div class="d-flex align-items-center mb-3 mb-md-0">
                            @if (!string.IsNullOrEmpty(avatarUrl))
                            {
                                <img src="@avatarUrl" class="rounded-circle shadow-sm me-4 border" style="width: 55px; height: 55px; object-fit: cover;" alt="@fullName" />
                            }
                            else
                            {
                                <div class="bg-primary bg-gradient text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm me-4" style="width: 55px; height: 55px; font-size: 1.3rem; font-weight: bold;">
                                    @initials
                                </div>
                            }

                            <div>
                                <div class="fs-5 fw-bold text-dark d-flex align-items-center flex-wrap gap-2 mb-1">
                                    @fullName
                    
                                    @if (member.Role == "Sahip")
                                    {
                                        <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill border border-primary border-opacity-25" style="font-size: 0.75rem;">
                                            <i class="bi bi-star-fill me-1"></i> Kurucu
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill border border-secondary border-opacity-25" style="font-size: 0.75rem;">
                                            Üye
                                        </span>
                                    }

                                    @if (member.UserId == Model.CurrentUserId)
                                    {
                                        <span class="badge bg-success text-white rounded-pill shadow-sm" style="font-size: 0.75rem;">
                                            Sen
                                        </span>
                                    }
                                </div>
                                <div class="text-muted small fw-medium">
                                    <i class="bi bi-envelope text-secondary me-1"></i> @member.User.Email
                                </div>
                            </div>
                        </div>

                        <div class="ms-md-4">
                            @if (Model.CurrentUserRole == "Sahip" && member.UserId != Model.CurrentUserId)
                            {
                                <form method="post" asp-page-handler="RemoveMember" class="d-inline" onsubmit="return confirm('Bu üyeyi ekipten çıkarmak istediğinize emin misiniz?');">
                                    <input type="hidden" name="targetUserId" value="@member.UserId" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm fw-bold rounded-pill px-4 shadow-sm hover-scale">
                                        <i class="bi bi-person-dash me-1"></i> Ekipten Çıkar
                                    </button>
                                </form>
                            }

                            @if (Model.CurrentUserRole == "Üye" && member.UserId == Model.CurrentUserId)
                            {
                                <form method="post" asp-page-handler="LeaveWorkspace" class="d-inline" onsubmit="return confirm('Bu çalışma alanından ayrılmak istediğinize emin misiniz?');">
                                    <button type="submit" class="btn btn-danger btn-sm fw-bold rounded-pill px-4 shadow-sm hover-scale">
                                        <i class="bi bi-box-arrow-right me-1"></i> Ekipten Ayrıl
                                    </button>
                                </form>
                            }
                        </div>
                    </li>
                }
            </ul>
        </div>
    </div>
</div>

@if (Model.CurrentUserRole == "Sahip" && !Model.WorkspaceName.Contains("Kişisel"))
{
    <div class="modal fade" id="deleteWorkspaceModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="modal-header bg-danger text-white border-0 py-4">
                    <h5 class="modal-title fw-bold" id="deleteModalLabel"><i class="bi bi-exclamation-octagon-fill me-2"></i> Tehlikeli Bölge</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4 bg-light">
                    <h5 class="text-danger fw-bold mb-3">Çalışma Alanını Tamamen Sil</h5>
                    <p class="text-muted" style="line-height: 1.7;">
                        Bu işlem <strong>kesinlikle geri alınamaz.</strong> Çalışma alanını sildiğinizde içerideki tüm takım arkadaşlarınız ekipten atılacak, tüm açık davet linkleri iptal edilecek ve bu alana ait tüm toplantı özetleri sistemden kalıcı olarak yok olacaktır.
                    </p>
                    <div class="alert alert-warning border-0 rounded-3 mt-4 mb-0">
                        <i class="bi bi-info-circle-fill me-2"></i> Gerçekten bu çalışma alanını kalıcı olarak silmek istediğinize emin misiniz?
                    </div>
                </div>
                <div class="modal-footer bg-white border-top py-3">
                    <button type="button" class="btn btn-light rounded-pill px-4 fw-bold" data-bs-dismiss="modal">Vazgeç</button>
                    <form method="post" asp-page-handler="DeleteWorkspace">
                        <button type="submit" class="btn btn-danger rounded-pill px-4 fw-bold shadow-sm">
                            <i class="bi bi-trash3-fill me-1"></i> Evet, Kalıcı Olarak Sil
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        // Initialize Bootstrap Tooltips for disabled elements
        document.addEventListener("DOMContentLoaded", function () {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl)
            });
        });
    </script>
}